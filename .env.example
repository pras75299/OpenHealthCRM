# Healthcare CRM - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# === DATABASE ===
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# === TWILIO (SMS & WhatsApp) ===
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_WHATSAPP_NUMBER="+1234567890"

# === EMAIL (Nodemailer - Gmail/SendGrid) ===
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your_app_password_here"

# === STRIPE (Payments) ===
STRIPE_SECRET_KEY="your_stripe_secret_key_here"
STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key_here"
STRIPE_WEBHOOK_SECRET="your_webhook_secret_here"

# === AUTHENTICATION ===
NEXTAUTH_SECRET="generate_a_strong_random_secret_here"
NEXTAUTH_URL="https://yourdomain.com"

# === SCHEDULED TASKS (CRON) ===
CRON_SECRET="generate_a_strong_secret_for_cron_jobs"

# === REDIS (Optional - for queue/caching) ===
REDIS_URL="redis://localhost:6379"

# === NODE ENVIRONMENT ===
NODE_ENV="production"

# === LOGGING ===
LOG_LEVEL="info"

# === API KEYS (Optional) ===
SENTRY_DSN="https://your_sentry_key@sentry.io/project_id"
